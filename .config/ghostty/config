# Ghostty Configuration
# Migrated from Kitty configuration
# ========================================

# Font settings
font-family = Cousine Nerd Font Mono
font-size = 13

# Color space: use native sRGB blending to match Kitty's behavior
# Linux default is "linear-corrected" which can make colors look different
alpha-blending = native

# Disable minimum contrast adjustment to prevent color shifting
minimum-contrast = 1

# Window appearance
window-decoration = false
background = #000000
cursor-style = block

# Make bar cursor thicker (applies to insert mode in vim)
# Positive value increases thickness, supports pixels or percentages
adjust-cursor-thickness = 2

#theme = Nvim Dark
# Kitty default color palette (matches Kitty's built-in theme)
palette = 0=#000000
palette = 8=#767676
palette = 1=#cc0403
palette = 9=#f2201f
palette = 2=#19cb00
palette = 10=#1fef00
palette = 3=#cecb00
palette = 11=#f0f900
palette = 4=#0d73cc
palette = 12=#1687f9
palette = 5=#cb1ed1
palette = 13=#ef00f6
palette = 6=#0dcdcd
palette = 14=#14ffff
palette = 7=#dddddd
palette = 15=#ffffff

# CJK font fallback (matching Kitty's symbol_map for Chinese characters)
font-codepoint-map = U+4E00-U+9FFF,U+3400-U+4DBF,U+20000-U+2A6DF,U+2A700-U+2B73F,U+2B740-U+2B81F,U+2B820-U+2CEAF,U+F900-U+FAFF,U+2F800-U+2FA1F=WenQuanYi Zen Hei

# Disable ligatures when cursor is over them (matching Kitty's disable_ligatures never)
font-shaping-break = no-cursor

# Cursor settings (matching Kitty's cursor_blink_interval 0)
cursor-style-blink = false

# Mouse settings (matching Kitty's mouse_hide_wait -1)
mouse-hide-while-typing = true

# Copy on select (matching Kitty's copy_on_select clipboard)
# Ghostty's default behavior already copies to clipboard on selection

# Audio bell disabled (matching Kitty's enable_audio_bell no)
# Ghostty has no audio bell by default

# ========================================
# Key bindings
# ========================================

# Copy/Paste
keybind = super+c=copy_to_clipboard:mixed
keybind = shift+insert=paste_from_selection

# Window management
keybind = super+1=new_window

# Font size controls
keybind = ctrl+shift+j=decrease_font_size:1
keybind = ctrl+shift+k=increase_font_size:1
keybind = ctrl+shift+space=reset_font_size

# Tab management
keybind = ctrl+shift+t=new_tab

# Tab navigation
keybind = ctrl+shift+tab=previous_tab
keybind = ctrl+tab=next_tab
keybind = ctrl+alt+1=goto_tab:1
keybind = ctrl+alt+2=goto_tab:2
keybind = ctrl+alt+3=goto_tab:3
keybind = ctrl+alt+4=goto_tab:4
keybind = ctrl+alt+5=goto_tab:5
keybind = ctrl+alt+6=goto_tab:6
keybind = ctrl+alt+7=goto_tab:7
keybind = ctrl+alt+8=goto_tab:8
keybind = ctrl+alt+9=last_tab

# Special key combinations
keybind = ctrl+enter=toggle_fullscreen
keybind = ctrl+shift+enter=toggle_split_zoom

# ========================================
# Adjustments (matching Kitty's modify_font settings)
# ========================================
# Kitty had: modify_font underline_position -2, modify_font underline_thickness 120%
# Ghostty equivalents:
# adjust-underline-position = -2
# adjust-underline-thickness = 20%
